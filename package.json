{
  "name": "p5mandelbrot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production tsc && vite build",
    "preview": "vite preview",
    "dev-p": "pnpm run build && pnpm run preview",
    "test": "vitest",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit 2>&1",
    "server": "tsx src/server/index.ts",
    "wasm:build": "cd wasm-fp && wasm-pack build --target web && mv pkg/apfp_bg.wasm ../public/wasm/ && echo '*.wasm' > pkg/.gitignore",
    "dev-all": "cross-env VITE_P5_MANDELBROT_DEVELOPMENT=true run-p dev server",
    "poi:convert": "tsx scripts/convert-poi-list.ts",
    "poi:sync": "gcloud storage rsync --delete-unmatched-destination-objects --recursive public/preset-poi/ gs://p5mandelbrot-preset-poi/",
    "poi:pull": "gcloud storage rsync --recursive gs://p5mandelbrot-preset-poi/ public/preset-poi/",
    "worker:dev": "wrangler dev --config workers/gcs-proxy/wrangler.toml",
    "worker:deploy": "wrangler deploy --config workers/gcs-proxy/wrangler.toml"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "@mantine/hooks": "8.3.16",
    "@tabler/icons-react": "3.40.0",
    "bignumber.js": "9.3.1",
    "chroma-js": "3.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "culori": "4.0.2",
    "d3-color": "3.1.0",
    "d3-scale-chromatic": "3.1.0",
    "es-toolkit": "1.45.1",
    "eventmit": "3.0.6",
    "hono": "4.12.8",
    "idb-keyval": "6.2.2",
    "lodash.throttle": "4.1.1",
    "lucide-react": "0.577.0",
    "neverthrow": "8.2.0",
    "next-themes": "0.4.6",
    "p5": "1.11.11",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "typegpu": "0.10.2"
  },
  "devDependencies": {
    "@radix-ui/colors": "3.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/chroma-js": "3.1.2",
    "@types/culori": "4.0.1",
    "@types/d3-color": "3.1.3",
    "@types/d3-scale-chromatic": "3.1.0",
    "@types/lodash.throttle": "4.1.9",
    "@types/node": "22.16.4",
    "@types/p5": "1.7.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@webgpu/types": "0.1.69",
    "cross-env": "10.1.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.1",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "unplugin-typegpu": "0.10.2",
    "vite": "8.0.1",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">22.22.0"
  }
}
